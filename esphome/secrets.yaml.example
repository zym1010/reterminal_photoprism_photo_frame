# Copy this file to secrets.yaml (which is gitignored) and fill in real values.

wifi_ssid: "YOUR_WIFI_SSID"
wifi_password: "YOUR_WIFI_PASSWORD"

# Generate your own random values for these, e.g.:
#   python3 -c "import base64, os; print(base64.b64encode(os.urandom(32)).decode())"   # api key
#   python3 -c "import base64, os; print(base64.b64encode(os.urandom(18)).decode().rstrip('='))"  # ota/ap passwords
eink_photo_frame_api_key: "GENERATE_YOUR_OWN_32_BYTE_BASE64_KEY"
eink_photo_frame_ota_password: "GENERATE_YOUR_OWN_OTA_PASSWORD"
eink_photo_frame_ap_password: "GENERATE_YOUR_OWN_AP_PASSWORD"
