# Copy to .env (gitignored, never commit) and fill in your own values for
# local testing.
#
# Prefer the device's IP over its eink-photo-frame.local mDNS name here -
# when this runs in Docker on plain bridge networking (the default/
# recommended mode - see README), mDNS resolution can fail since Docker's
# bridge network doesn't forward the multicast traffic it needs. Same
# pattern as PHOTOPRISM_URL/bridge_url elsewhere in this project, which are
# already hardcoded IPs for the same reason. Make sure your router/NAS has a
# DHCP reservation for the device's MAC address so this doesn't drift.
DEVICE_HOST=192.168.68.63
# Same value as `eink_photo_frame_api_key` in esphome/secrets.yaml
DEVICE_API_KEY=your_base64_api_key_here
LOG_FILE=/tmp/device.log
